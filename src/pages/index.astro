---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JournalItem from '../components/JournalItem.astro';
import LabCard from '../components/LabCard.astro';
import { getCollection } from 'astro:content';

// 从 Content Collections 获取最新文章
const allPosts = await getCollection('posts', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
});

const latestPosts = allPosts
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
    .slice(0, 3);

// Span 模式
const spanPatterns = [
    "col-span-12 md:col-span-8",
    "col-span-12 md:col-span-6",
    "col-span-12 md:col-span-6"
];
---

<BaseLayout title="THE FRAME | Digital Curation">
    <Header />
    
    <main class="min-h-screen pt-24 md:pt-32">
        <!-- Hero Section -->
        <header class="grid grid-cols-12 gap-4 md:gap-8 mb-20 md:mb-40 px-[4vw]">
            <div class="col-span-12 md:col-span-8 relative">
                <div class="hero-tag font-mono text-xs text-[var(--text-secondary)] mb-4 md:mb-8 tracking-widest pl-1">
                    VOL. 01 / 2026
                </div>
                <!-- Parallax Target -->
                <h1 class="hero-title text-[clamp(2.5rem,9vw,8rem)] leading-[0.95] tracking-tighter -ml-[0.05em] font-bold">
                    2026:<br>
                    爱、死亡、<br>
                    <span class="text-gr">人工智能.</span>
                </h1>
                <p class="mt-4 md:mt-6 text-sm opacity-60 font-mono tracking-widest max-w-md">
                    记录想法，分享发现。
                </p>
            </div>
            
            <div class="col-span-12 md:col-span-4 flex flex-col justify-end items-start md:items-end pb-4 mt-8 md:mt-0">
                <p class="max-w-xs text-sm leading-relaxed opacity-70 mb-4 md:mb-8 md:text-right">
                    一个结构主义的数字策展空间。<br>
                    探索代码与美学的边界，<br>
                    在无序的信息流中构建秩序。
                </p>
                <div class="w-12 h-[1px] bg-current"></div>
            </div>
        </header>

        <!-- Journal Section (Bento Grid) -->
        <section class="mb-20 md:mb-40 px-[4vw]">
            <div class="flex justify-between items-end mb-8 md:mb-12 pb-4">
                <h2 class="text-2xl md:text-4xl tracking-tight font-bold text-[var(--accent)]">碎碎念 <span class="text-base md:text-lg opacity-40 ml-2 font-light text-[var(--text)]">/ Journal</span></h2>
                <span class="font-mono text-xs opacity-50">({String(latestPosts.length).padStart(2, '0')})</span>
            </div>

            {latestPosts.length > 0 ? (
                <div class="bento-grid">
                    {latestPosts.map((post, index) => (
                        <>
                            <div class={spanPatterns[index]} data-reveal>
                                <JournalItem 
                                    title={post.data.title}
                                    category={`${post.data.category || '未分类'} / ${String(index + 1).padStart(2, '0')}`}
                                    image={post.data.heroImage || `https://picsum.photos/seed/${post.slug}/1200/800`}
                                    href={`/journal/${post.slug}`}
                                    span="w-full"
                                />
                            </div>
                            {index === 0 && (
                                <div class="col-span-12 md:col-span-4 flex flex-col justify-end p-6" data-reveal>
                                    <p class="font-serif text-sm leading-loose opacity-60 mb-8 italic">
                                        "Form follows function - that has been misunderstood. Form and function should be one, joined in a spiritual union."
                                    </p>
                                </div>
                            )}
                        </>
                    ))}
                </div>
            ) : (
                <div class="text-center py-16 opacity-60">
                    <p class="text-xl mb-4">还没有文章</p>
                    <p class="font-mono text-sm">
                        访问 <a href="/keystatic" class="text-[var(--accent)] underline">/keystatic</a> 添加你的第一篇文章
                    </p>
                </div>
            )}

            <div class="mt-12 text-center">
                <a href="/journal" class="inline-block px-8 py-3 rounded-full bg-[var(--surface)] shadow-sm hover:shadow-md text-sm font-medium tracking-wide transition-all hover:text-[var(--accent)]">
                    浏览全部日志 &rarr;
                </a>
            </div>
        </section>

        <!-- Lab Section (Horizontal Scroll) -->
        <section class="mb-20 px-[4vw] overflow-hidden">
            <div class="flex justify-between items-end mb-8 md:mb-12 pb-4">
                <h2 class="text-2xl md:text-4xl tracking-tight font-bold text-[var(--text)]">实验室 <span class="text-base md:text-lg opacity-40 ml-2 font-light text-[var(--text)]">/ Laboratory</span></h2>
                <span class="font-mono text-xs opacity-50">滑动 &rarr;</span>
            </div>

            <div class="lab-container py-4 md:py-8 -mx-[4vw] px-[4vw]" id="labScroll">
                <LabCard 
                    code="EXP_001" 
                    name="Fluid Typography" 
                    icon="type"
                    image="https://upload.wikimedia.org/wikipedia/commons/thumb/e/ea/Van_Gogh_-_Starry_Night_-_Google_Art_Project.jpg/1280px-Van_Gogh_-_Starry_Night_-_Google_Art_Project.jpg"
                />
                <LabCard 
                    code="EXP_002" 
                    name="WebGL Distortion" 
                    icon="waves"
                    image="https://upload.wikimedia.org/wikipedia/commons/thumb/0/0f/1665_Girl_with_a_Pearl_Earring.jpg/800px-1665_Girl_with_a_Pearl_Earring.jpg"
                />
                <LabCard 
                    code="EXP_003" 
                    name="React Server Components" 
                    icon="server"
                    image="https://upload.wikimedia.org/wikipedia/commons/thumb/e/ec/Mona_Lisa%2C_by_Leonardo_da_Vinci%2C_from_C2RMF_retouched.jpg/800px-Mona_Lisa%2C_by_Leonardo_da_Vinci%2C_from_C2RMF_retouched.jpg"
                />
                <LabCard 
                    code="EXP_004" 
                    name="Generative Art" 
                    icon="aperture"
                    image="https://upload.wikimedia.org/wikipedia/commons/thumb/b/b4/The_Scream.jpg/800px-The_Scream.jpg"
                />
                <LabCard 
                    code="EXP_005" 
                    name="Dark Mode Token" 
                    icon="moon"
                    image="https://upload.wikimedia.org/wikipedia/commons/thumb/9/94/Monet_-_Impression%2C_Sunrise.jpg/1280px-Monet_-_Impression%2C_Sunrise.jpg"
                />
            </div>
        </section>
    </main>

    <Footer />
</BaseLayout>

<script>
    import { createIcons, Type, Waves, Server, Aperture, Moon, ArrowUp } from 'lucide';

    // Animation & Logic
    function init() {
        // 1. Icons
        createIcons({
             icons: { Type, Waves, Server, Aperture, Moon, ArrowUp }
        });

        // 2. Scroll Reveal
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.setAttribute('data-reveal', 'active');
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('[data-reveal]').forEach(el => observer.observe(el));

        // 3. Parallax
        const heroTitle = document.querySelector('.hero-title') as HTMLElement;
        const heroTag = document.querySelector('.hero-tag') as HTMLElement;
        
        if (heroTitle && heroTag) {
            window.addEventListener('scroll', () => {
                const scrolled = window.scrollY;
                if (scrolled < 800) {
                     heroTitle.style.transform = `translateY(${scrolled * 0.2}px) skewY(${scrolled * 0.01}deg)`;
                     heroTag.style.transform = `translateX(${scrolled * 0.5}px)`;
                }
            });
        }

        // 4. Lab Horizontal Scroll with Touch Support
        const labContainer = document.getElementById('labScroll');
        if (labContainer) {
            // Desktop: wheel scroll converts to horizontal
            const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
            
            if (!isTouchDevice) {
                labContainer.addEventListener('wheel', (e) => {
                    if (e.deltaY !== 0) {
                        e.preventDefault();
                        labContainer.scrollLeft += e.deltaY;
                    }
                }, { passive: false });
            }

            // Mobile: touch drag with momentum
            let isDown = false;
            let startX: number;
            let scrollLeft: number;
            let velocity = 0;
            let lastX: number;
            let lastTime: number;

            labContainer.addEventListener('touchstart', (e) => {
                isDown = true;
                startX = e.touches[0].pageX - labContainer.offsetLeft;
                scrollLeft = labContainer.scrollLeft;
                lastX = startX;
                lastTime = Date.now();
                velocity = 0;
            }, { passive: true });

            labContainer.addEventListener('touchmove', (e) => {
                if (!isDown) return;
                const x = e.touches[0].pageX - labContainer.offsetLeft;
                const walk = (x - startX) * 1.5;
                labContainer.scrollLeft = scrollLeft - walk;
                
                const now = Date.now();
                const dt = now - lastTime;
                if (dt > 0) {
                    velocity = (lastX - x) / dt;
                }
                lastX = x;
                lastTime = now;
            }, { passive: true });

            labContainer.addEventListener('touchend', () => {
                isDown = false;
                if (Math.abs(velocity) > 0.1) {
                    const momentum = velocity * 150;
                    labContainer.scrollTo({
                        left: labContainer.scrollLeft + momentum,
                        behavior: 'smooth'
                    });
                }
            }, { passive: true });
        }
    }

    // Init on load and swap
    init();
    document.addEventListener('astro:page-load', init);
</script>
